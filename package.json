{
  "name": "windows-explorer-web",
  "version": "0.1.0",
  "private": true,
  "description": "Windows Explorer–like web app: Bun + Elysia + Drizzle + Postgres backend, Vue 3 + Tailwind frontend.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "format": "prettier --write \"**/*.{ts,tsx,vue,js,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,vue,js,json,md,css,html}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
