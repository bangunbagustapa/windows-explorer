{
  "name": "@windows-explorer/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Bun + Elysia + Drizzle backend with service+repository layering.",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "bun test",
    "db:setup": "bun src/infrastructure/db/setup-db.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun src/infrastructure/db/seed.ts"
  },
  "dependencies": {
    "@windows-explorer/shared": "workspace:*",
    "elysia": "^1.1.0",
    "@elysiajs/cors": "^1.1.0",
    "postgres": "^3.4.4",
    "drizzle-orm": "^0.36.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.29.1",
    "typescript": "^5.6.3"
  }
}
